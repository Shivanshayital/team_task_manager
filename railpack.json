{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        "npm ci --ignore-scripts"
      ]
    },
    "build": {
      "inputs": [
        {
          "step": "install"
        }
      ],
      "commands": [
        "npm --prefix client ci --include=dev",
        "npm --prefix client run build",
        "npm --prefix server ci --omit=dev"
      ]
    }
  },
  "deploy": {
    "startCommand": "node server/server.js"
  }
}
